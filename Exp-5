//Non Preemptive Process Scheduling - FCFS
//SKD
#include <stdio.h>
int main()
{
int n, i;
// at[] = Arrival Time
// bt[] = Burst Time
// ct[] = Completion Time
// wt[] = Waiting Time
// tat[] = Turnaround Time
int at[10], bt[10], ct[10], wt[10], tat[10];

// Read number of processes
printf("Enter number of processes: ");
scanf("%d", &n);

// Read arrival time and burst time for each process
printf("Enter Arrival Time and Burst Time:\n");
for (i = 0; i < n; i++)
{
printf("Process P%d: ", i + 1);
scanf("%d %d", &at[i], &bt[i]);
}

// Completion time of first process
// First process starts execution at its arrival time
ct[0] = at[0] + bt[0];

// Calculate completion time for remaining processes
for (i = 1; i < n; i++)
{
// If previous process finishes before current process arrives
if (ct[i - 1] < at[i])
{
// CPU remains idle until current process arrives
ct[i] = at[i] + bt[i];
}
else
{
// CPU is busy, so current process starts immediately
ct[i] = ct[i - 1] + bt[i];
}
}
// Calculate Turnaround Time and Waiting Time
for (i = 0; i < n; i++)
{
// Turnaround Time = Completion Time - Arrival Time
tat[i] = ct[i] - at[i];

// Waiting Time = Turnaround Time - Burst Time
wt[i] = tat[i] - bt[i];
}

// Display the result in tabular form
printf("\nProcess\t\tAT\t\t\tBT\t\t\tCT\t\t\tTAT\t\t\tWT\n");
for (i = 0; i < n; i++)
{
printf("P%d\t\t\t%d\t\t\t%d\t\t\t%d\t\t\t%d\t\t\t%d\n",

i + 1, at[i], bt[i], ct[i], tat[i], wt[i]);
}
return 0;
}
